<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Push Notifications entitlement. Use "production" for App Store / TestFlight
	     builds. Xcode normally manages this file when you add the
	     "Push Notifications" capability under Signing & Capabilities. -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
